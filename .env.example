# SQL Server connection string (Prisma). Local dev uses Windows Authentication
# against the default (local) instance; production should use a dedicated
# SQL login instead of integratedSecurity, e.g.:
# DATABASE_URL="sqlserver://HOST:1433;database=qrmenu;user=qrmenu_app;password=CHANGE_ME;encrypt=true;trustServerCertificate=true"
DATABASE_URL="sqlserver://localhost:1433;database=qrmenu_dev;integratedSecurity=true;trustServerCertificate=true;encrypt=true"

# Auth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="change-me"

# Public base URL used to build absolute /menu/[slug] links for QR codes.
# In production, set this to the real domain (e.g. https://menu.example.com)
# — QR codes are generated from this value, so it must match what customers
# actually reach.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
